#!/usr/bin/env fish

# --- Basics -------------------------------------------------------------------

source "$HOME/.dotfiles/linux/scripts/profile/exports"
export DOTFILES_SCRIPTS="$DOTFILES/linux/scripts"


fish_add_path "$DOTFILES_SCRIPTS" 2>/dev/null
fish_add_path "$HOME/.local/bin" 2>/dev/null
fish_add_path "$HOME/.cargo/bin" 2>/dev/null
fish_add_path "$HOME/Qt/Tools/QtCreator/bin" 2>/dev/null

alias configreload='source $HOME/.config/fish/config.fish'
source "$DOTFILES_SCRIPTS/profile/aliases"

# --- Functions ----------------------------------------------------------------

# mkdir + cd
function mkcd -a dir
    mkdir -p "$dir" && pushd "$dir"
end

# yazi
function y
    set tmp (mktemp -t "yazi-cwd.XXXXXX")
    command yazi $argv --cwd-file="$tmp"
    if read -z cwd <"$tmp"; and [ "$cwd" != "$PWD" ]; and test -d "$cwd"
        builtin cd -- "$cwd"
    end
    rm -f -- "$tmp"
end

# bring to fg latest job in bg
bind \cz 'fg 2>/dev/null; commandline -f repaint'

# --- Tweaks -------------------------------------------------------------------

set -x MANROFFOPT -c
set -x MANPAGER "sh -c 'col -bx | bat -l man -p'"

# --- Prompt -------------------------------------------------------------------

starship init fish | source

# --- External -----------------------------------------------------------------

fish_add_path "$HOME/omi/scripts/bash" 2>/dev/null

if test -x "/usr/bin/micromamba"
    set -gx MAMBA_EXE "/usr/bin/micromamba"
    set -gx MAMBA_ROOT_PREFIX "$HOME/.local/share/mamba"
    $MAMBA_EXE shell hook --shell fish --root-prefix $MAMBA_ROOT_PREFIX | source
end
