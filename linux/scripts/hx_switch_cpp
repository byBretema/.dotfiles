#!/usr/bin/env bash

# User input
filepath=${1}
filepath=$(printf "%s" "$filepath" | tr -d '\n\r')

# Extract info
filename=$(basename "$filepath")
dir=$(dirname "$filepath")
ext="${filename##*.}"
name="${filename%.*}"

# Helpers
_done()     { printf "%s" "$1"; exit 0; }
_fallback() { _done $filepath; }

# Get target list based on extension
case "$ext" in
    h|hh|hpp|hxx|cuh|vert) targets=("cpp" "cc" "c" "cxx" "cu" "frag") ;;
    c|cc|cpp|cxx|cu|frag)  targets=("h" "hpp" "hh" "hxx" "cuh" "vert") ;;
    *)                     _fallback;;
esac

# Check on the same dir
for t in "${targets[@]}"; do
    candidate="$dir/$name.$t"
    if [[ -f "$candidate" ]]; then _done "$candidate"; fi
done

# If not found, get closest root: (.git, CMakeLists.txt, ...)
root="$dir"
while [[ "$root" != "/" && "$root" != "." && ! -d "$root/.git" && ! -f "$root/CMakeLists.txt" && ! -f "$root/Makefile" ]]; do
    root=$(dirname "$root")
done
[[ "$root" == "/" ]] && root="$dir"

# Deep search the project tree for the file
for t in "${targets[@]}"; do
    found=$(find "$root" -type f -name "$name.$t" -not -path '*/\.*' | head -n 1) # skip .files .dirs
    if [[ -n "$found" ]]; then _done "$found"; fi
done

_fallback
