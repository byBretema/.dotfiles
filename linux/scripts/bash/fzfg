#!/usr/bin/env bash

case_flag=""
args=()
for arg in "$@"; do
  case "$arg" in
    -i|--ignore-case)     case_flag="-i" ;;
    -h|--help)            echo "Usage: fzfg [-i] <pattern> [open-cmd]"; exit 0 ;;
    *)                    args+=("$arg") ;;
  esac
done
pattern="${args[0]:?Usage: fzfg [-i] <pattern> [open-cmd]}"
opencmd="${args[1]:-}"

BUFFER=25

list_file=$(mktemp) || exit 1
result_file=$(mktemp) || exit 1
preview_script=$(mktemp) || exit 1
fzf_script=$(mktemp) || exit 1
trap 'rm -f "$list_file" "$result_file" "$preview_script" "$fzf_script"' EXIT

escape_pattern() {
  perl -e '
    my $s = shift;
    my $out = "";
    my $i = 0;
    while ($i < length $s) {
      my $c = substr($s, $i, 1);
      if ($c eq "\\" && $i + 1 < length $s) {
        $out .= "\\" . substr($s, $i + 1, 1);
        $i += 2;
      } elsif ($c eq "." && substr($s, $i + 1, 1) eq "*") {
        $out .= ".*";
        $i += 2;
      } elsif ($c eq "[" && substr($s, $i, 4) eq "[ ]*") {
        $out .= "[ ]*";
        $i += 4;
      } elsif ($c =~ /[.^\$*+?{}()\[\]|\\]/) {
        $out .= "\\" . $c;
        $i++;
      } else {
        $out .= $c;
        $i++;
      }
    }
    print $out;
  ' -- "$1"
}
processed=$(escape_pattern "$pattern")

cat > "$preview_script" <<'PREVIEW_SCRIPT_EOF'
#!/usr/bin/env bash
item="$1"
raw=$(printf '%s' "$item" | sed 's/\x1b\[[0-9;]*m//g')
count=${raw##*:}
rest=${raw%:*}
l=${rest##*:}
f=${rest%:*}
BUFFER=25
bat --color=always --style=numbers --line-range "$((l>BUFFER?l-BUFFER:1))":"$((l+BUFFER))" \
    --highlight-line "$l":"$((l+count-1))" "$f"
PREVIEW_SCRIPT_EOF

rg --color never -nU ${case_flag:+"$case_flag"} -e "$processed" | \
  awk -F: '
    function emit() {
      if (file != "") print file ":" startline ":" count
    }
    {
      if ($1 != file || $2 != prevline + 1) {
        emit()
        file = $1
        startline = $2
        count = 1
      } else {
        count++
      }
      prevline = $2
    }
    END { emit() }
  ' | \
  awk -F: '!seen[$1]++' | \
  sed "s|^\(.*/\)|$(printf '\033[34m')\1$(printf '\033[39m')|" > "$list_file"

binds='ctrl-t:toggle-preview,alt-p:preview-up,alt-n:preview-down,alt-t:preview-top'

cat > "$fzf_script" <<FZF_SCRIPT_EOF
SHELL=$(which bash) fzf --ansi --cycle --reverse --height=100% \
  --prompt "" --info=inline-right --no-separator --no-scrollbar \
  --bind "$binds" \
  --border=none --color=bg+:#313244,preview-border:white,pointer:#ffffff,gutter:#1E1E2E \
  --pointer ">" \
  --preview "bash $preview_script {}" \
  --preview-window right,border-bold \
  < $list_file > $result_file
FZF_SCRIPT_EOF

script -q -c "bash $fzf_script" /dev/null </dev/tty >/dev/tty 2>/dev/null

result=$(cat "$result_file")
[ -n "$result" ] || exit 1

if [ -n "$opencmd" ]; then
  raw=$(printf '%s' "$result" | sed 's/\x1b\[[0-9;]*m//g')
  rest=${raw%:*}
  l=${rest##*:}
  f=${rest%:*}
  exec "$opencmd" "$f:$l"
fi

printf '%s\n' "$result"
