#!/usr/bin/env bash

case_flag=""
pattern=""
opencmd=""

usage() {
  cat <<EOF
Usage: fzfg [options] [-p <pattern>]

Options:
  -p <pattern>     Initial search pattern (optional)
  -c <open-cmd>    Command to open selected file (e.g. hx, vim)
  -i, --ignore-case  Case-insensitive search
  -h, --help       Show this help message
EOF
  exit 0
}

for arg; do [[ "$arg" == "--help" ]] && usage; done

while getopts ":p:c:ih" opt; do
  case "$opt" in
    p) pattern="$OPTARG" ;;
    c) opencmd="$OPTARG" ;;
    i) case_flag="-i" ;;
    h) usage ;;
    *) usage ;;
  esac
done

BUFFER=25

if [ -z "$pattern" ]; then
  query_file=$(mktemp) || exit 1
  trap 'rm -f "$query_file"' EXIT
  script -q -c \
    "SHELL=$(which bash) fzf --print-query --prompt=\"Pattern: \" \
      --reverse --height=100% --info=hidden --no-separator --no-scrollbar \
      --border=none --color=bg+:#313244,pointer:#ffffff,gutter:#1E1E2E \
      --pointer \">\" \
      < /dev/null > $query_file" \
    /dev/null </dev/tty >/dev/tty 2>/dev/null
  pattern=$(sed -n '1p' "$query_file" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
  [ -n "$pattern" ] || exit 1
fi

escaped=$(perl -e '
  my $s = shift;
  my $out = "";
  my $i = 0;
  while ($i < length $s) {
    my $c = substr($s, $i, 1);
    if ($c eq "\\" && $i + 1 < length $s) {
      $out .= "\\" . substr($s, $i + 1, 1);
      $i += 2;
    } elsif ($c eq "." && substr($s, $i + 1, 1) eq "*") {
      $out .= ".*";
      $i += 2;
    } elsif ($c eq "[" && substr($s, $i, 4) eq "[ ]*") {
      $out .= "[ ]*";
      $i += 4;
    } elsif ($c =~ /[.^\$*+?{}()\[\]|\\]/) {
      $out .= "\\" . $c;
      $i++;
    } else {
      $out .= $c;
      $i++;
    }
  }
  print $out;
' -- "$pattern")

preview_script=$(mktemp) || exit 1
list_file=$(mktemp) || exit 1
result_file=$(mktemp) || exit 1
trap 'rm -f "$preview_script" "$list_file" "$result_file"' EXIT

cat > "$preview_script" <<'PREVIEW_EOF'
#!/usr/bin/env bash
item="$1"
raw=$(printf '%s' "$item" | sed 's/\x1b\[[0-9;]*m//g')
count=${raw##*:}
rest=${raw%:*}
l=${rest##*:}
f=${rest%:*}
BUFFER=25
bat --color=always --style=numbers --line-range "$((l>BUFFER?l-BUFFER:1))":"$((l+BUFFER))" \
    --highlight-line "$l":"$((l+count-1))" "$f"
PREVIEW_EOF
chmod +x "$preview_script"

rg --color never -nU ${case_flag:+"$case_flag"} -e "$escaped" | \
  awk -F: '
    function emit() {
      if (file != "") print file ":" startline ":" count
    }
    {
      if ($1 != file || $2 != prevline + 1) {
        emit()
        file = $1
        startline = $2
        count = 1
      } else {
        count++
      }
      prevline = $2
    }
    END { emit() }
  ' | \
  awk -F: '!seen[$1]++' | \
  sed "s|^\(.*/\)|$(printf '\033[34m')\1$(printf '\033[39m')|" > "$list_file"

[ -s "$list_file" ] || exit 1

binds='ctrl-t:toggle-preview,alt-p:preview-up,alt-n:preview-down,alt-t:preview-top'

fzf_script=$(mktemp) || exit 1
trap 'rm -f "$fzf_script"' EXIT

cat > "$fzf_script" <<FZF_SCRIPT_EOF
SHELL=$(which bash) fzf --ansi --cycle --reverse --height=100% \
  --prompt "" --info=inline-right --no-separator --no-scrollbar \
  --bind "$binds" \
  --border=none --color=bg+:#313244,preview-border:white,pointer:#ffffff,gutter:#1E1E2E \
  --pointer ">" \
  --preview "bash $preview_script {}" \
  --preview-window right,border-bold \
  < $list_file > $result_file
FZF_SCRIPT_EOF

script -q -c "bash $fzf_script" /dev/null </dev/tty >/dev/tty 2>/dev/null

result=$(cat "$result_file")
[ -n "$result" ] || exit 1

if [ -n "$opencmd" ]; then
  raw=$(printf '%s' "$result" | sed 's/\x1b\[[0-9;]*m//g')
  rest=${raw%:*}
  l=${rest##*:}
  f=${rest%:*}
  exec "$opencmd" "$f:$l"
fi

printf '%s\n' "$result"
