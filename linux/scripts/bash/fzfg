#!/usr/bin/env bash

# =============================================================================
# fzfg - fuzzy grep: interactively search files with rg and fzf
# =============================================================================

# --- Colors ------------------------------------------------------------------
readonly COLOR_GUTTER="#1e1e2e"
readonly COLOR_CURSOR_BG="#313244"
readonly COLOR_MATCH_BG="#89b4fa"
readonly COLOR_ACCENT="#ffffff"

readonly FZF_COLORS_PATTERN="bg+:${COLOR_CURSOR_BG},pointer:${COLOR_ACCENT},gutter:${COLOR_GUTTER}"
readonly FZF_COLORS_RESULT="bg+:${COLOR_CURSOR_BG},preview-border:${COLOR_ACCENT},pointer:${COLOR_ACCENT},gutter:${COLOR_GUTTER}"

readonly ANSI_PATH_FG="34"
readonly ANSI_PATH_FG_DEFAULT="39"
readonly ANSI_WORD_HL_BG=$'\e[48;2;137;180;250m'  # derived from COLOR_MATCH_BG (kept as literal for perf)
readonly ANSI_WORD_HL_FG=$'\e[38;2;30;30;46m'
readonly ANSI_RESET=$'\e[0m'

# --- Configuration -----------------------------------------------------------
readonly BUFFER=25
readonly MAX_HISTORY=50
readonly HISTFILE="${XDG_CACHE_HOME:-$HOME/.cache}/fzfg/history"
readonly FZF_OPTS="--reverse --height=100% --no-separator --no-scrollbar --border=none"

# --- State -------------------------------------------------------------------
case_flag=""
pattern=""
opencmd=""
_temp_files=()

# --- Helpers -----------------------------------------------------------------

usage() {
  cat <<EOF
Usage: fzfg [options] [-p <pattern>]

Options:
  -p <pattern>     Initial search pattern (optional)
  -c <open-cmd>    Command to open selected file (e.g. hx, vim)
  -i, --ignore-case  Case-insensitive search
  -h, --help       Show this help message
EOF
  exit 0
}

_temp() {
  local f
  f=$(mktemp) || exit 1
  _temp_files+=("$f")
  echo "$f"
}

_cleanup() {
  rm -f "${_temp_files[@]}"
}
trap _cleanup EXIT

_last_line() {
  awk 'NF{last=$0} END{print last}' "$1" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

_pty() {
  script -q -c "$*" /dev/null </dev/tty >/dev/tty 2>/dev/null
}

# --- Argument parsing --------------------------------------------------------
for arg; do [[ "$arg" == "--help" ]] && usage; done

while getopts ":p:c:ih" opt; do
  case "$opt" in
    p) pattern="$OPTARG" ;;
    c) opencmd="$OPTARG" ;;
    i) case_flag="-i" ;;
    h) usage ;;
    *) usage ;;
  esac
done

# --- Pattern input with history ----------------------------------------------
if [ -z "$pattern" ]; then
  mkdir -p "$(dirname "$HISTFILE")"

  items=$(_temp)
  query=$(_temp)

  [ -s "$HISTFILE" ] && head -n "$MAX_HISTORY" "$HISTFILE" > "$items"

  preview_cmd=$(_temp)
  {
    echo '#!/usr/bin/env bash'
    echo 'item=$1 query=$2'
    echo 'pat="$item"'
    echo '[ -n "$pat" ] || pat="$query"'
    echo '[ -z "$pat" ] && exit'
    echo "rg --color=always -nU ${case_flag:+"$case_flag"} -e \"\$pat\" 2>/dev/null | head -100"
  } > "$preview_cmd"
  chmod +x "$preview_cmd"

  _pty \
    "SHELL=$(which bash) fzf --print-query --prompt=\"Pattern: \" \
      $FZF_OPTS --info=inline-right \
      --color=\"$FZF_COLORS_RESULT\" \
      --pointer \">\" \
      --preview \"$preview_cmd '{}' '{q}'\" \
      --preview-window down,60%,border-bold < $items > $query"

  pattern=$(_last_line "$query")
  [ -n "$pattern" ] || exit 1

  {
    echo "$pattern"
    [ -f "$HISTFILE" ] && grep -vFx "$pattern" "$HISTFILE"
  } > "${HISTFILE}.tmp" && mv "${HISTFILE}.tmp" "$HISTFILE"
fi

# --- Escape pattern for ripgrep ---------------------------------------------
escaped=$(perl -e '
  my $s = shift;
  my $out = "";
  my $i = 0;
  while ($i < length $s) {
    my $c = substr($s, $i, 1);
    if ($c eq "\\" && $i + 1 < length $s) {
      $out .= "\\" . substr($s, $i + 1, 1);
      $i += 2;
    } elsif ($c eq "." && substr($s, $i + 1, 1) eq "*") {
      $out .= ".*";
      $i += 2;
    } elsif ($c eq "[" && substr($s, $i, 4) eq "[ ]*") {
      $out .= "[ ]*";
      $i += 4;
    } elsif ($c =~ /[.^\$*+?{}()\[\]|\\]/) {
      $out .= "\\" . $c;
      $i++;
    } else {
      $out .= $c;
      $i++;
    }
  }
  print $out;
' -- "$pattern")

# --- Save original pattern for preview word-highlighting ----------------------
pattern_file=$(_temp)
printf '%s' "$pattern" > "$pattern_file"

# --- Run ripgrep (JSON output), emit one entry per match (path:start_line:line_count) ----
list=$(_temp)

rg --json -U ${case_flag:+"$case_flag"} -e "$escaped" | \
  python3 -c '
import sys, json
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        obj = json.loads(line)
    except json.JSONDecodeError:
        continue
    if obj.get("type") != "match":
        continue
    data = obj.get("data", {})
    path = data.get("path", {}).get("text", "")
    line_number = data.get("line_number", 0)
    lines_text = data.get("lines", {}).get("text", "")
    line_count = lines_text.count("\n")
    if path and line_number:
        print(f"{path}:{line_number}:{line_count}")
  ' | \
  sed "s|^\(.*/\)|$(printf '\033[%sm' "$ANSI_PATH_FG")\1$(printf '\033[%sm' "$ANSI_PATH_FG_DEFAULT")|" > "$list"

[ -s "$list" ] || exit 1

# --- Result selection with fzf -----------------------------------------------
preview=$(_temp)
result=$(_temp)

cat > "$preview" <<'PREVIEW'
#!/usr/bin/env bash
item="$1"
hl_bg="$2"
hl_fg="$3"
hl_reset="$4"
raw=$(printf '%s' "$item" | sed 's/\x1b\[[0-9;]*m//g')
count=${raw##*:}
rest=${raw%:*}
l=${rest##*:}
f=${rest%:*}
pattern=$(cat "$FZFG_PATTERN_FILE")

bat --color=always --style=numbers --line-range "$((l>BUFFER?l-BUFFER:1))":"$((l+BUFFER))" \
    --highlight-line "$l":"$((l+count-1))" "$f" | \
perl -e '
  my $pat      = shift @ARGV;
  my $hl_bg    = shift @ARGV;
  my $hl_fg    = shift @ARGV;
  my $hl_reset = shift @ARGV;
  while (<>) {
    chomp;
    my $ansi = $_;
    my $raw = $ansi;
    $raw =~ s/\e\[[0-9;]*m//g;
    my @matches;
    while ($raw =~ /\Q$pat\E/g) {
      push @matches, { pos => pos($raw) - length($&), len => length($&) };
    }
    for my $m (reverse @matches) {
      my $bp = 0;
      my $rc = 0;
      my $sb = -1;
      my $eb = -1;
      while ($bp < length($ansi)) {
        if ($rc == $m->{pos} + $m->{len}) { $eb = $bp; last }
        if (substr($ansi, $bp) =~ /^\e\[[0-9;]*m/) {
          $bp += length($&);
          next;
        }
        $sb = $bp if $rc == $m->{pos};
        $bp++;
        $rc++;
      }
      $eb = $bp if $eb < 0;
      if ($sb >= 0 && $eb > $sb) {
        substr($ansi, $eb, 0) = $hl_reset;
        substr($ansi, $sb, 0) = $hl_bg . $hl_fg;
      }
    }
    print "$ansi\n";
  }
' "$pattern" "$hl_bg" "$hl_fg" "$hl_reset"
PREVIEW
chmod +x "$preview"

binds='ctrl-t:toggle-preview,alt-p:preview-up,alt-n:preview-down,alt-t:preview-top'

_pty \
  "SHELL=$(which bash) fzf --ansi --cycle \
    $FZF_OPTS --prompt=\"\" --info=inline-right \
    --bind=\"$binds\" \
    --color=\"$FZF_COLORS_RESULT\" \
    --pointer \">\" \
    --preview \"BUFFER=$BUFFER FZFG_PATTERN_FILE=$pattern_file bash $preview {} '$ANSI_WORD_HL_BG' '$ANSI_WORD_HL_FG' '$ANSI_RESET'\" \
    --preview-window right,border-bold \
    < $list > $result"

selection=$(cat "$result")
[ -n "$selection" ] || exit 1

# --- Open file or print result -----------------------------------------------
if [ -n "$opencmd" ]; then
  raw=$(printf '%s' "$selection" | sed 's/\x1b\[[0-9;]*m//g')
  rest=${raw%:*}
  l=${rest##*:}
  f=${rest%:*}
  exec "$opencmd" "$f:$l"
fi

printf '%s\n' "$selection"
