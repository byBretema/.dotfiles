#!/usr/bin/env bash

# =============================================================================
# fzfg - fuzzy grep: interactively search files with rg and fzf
# =============================================================================

# --- Colors ------------------------------------------------------------------
readonly COLOR_GUTTER="#1e1e2e"
readonly COLOR_CURSOR_BG="#313244"
readonly COLOR_MATCH_BG="#89b4fa"
readonly COLOR_ACCENT="#ffffff"
readonly COLOR_CONTENT_DIM="#6c7086"

readonly FZF_COLORS="bg+:${COLOR_CURSOR_BG},preview-border:${COLOR_ACCENT},pointer:${COLOR_ACCENT},gutter:${COLOR_GUTTER}"

readonly ANSI_PATH_FG="34"
readonly ANSI_PATH_FG_DEFAULT="39"
readonly ANSI_WORD_HL_BG=$'\e[48;2;137;180;250m'  # derived from COLOR_MATCH_BG (kept as literal for perf)
readonly ANSI_CONTENT_FG=$'\e[38;2;108;112;134m'  # derived from COLOR_CONTENT_DIM
readonly ANSI_WORD_HL_FG=$'\e[38;2;30;30;46m'
readonly ANSI_RESET=$'\e[0m'

# --- Configuration -----------------------------------------------------------
readonly BUFFER=25
readonly MAX_HISTORY=50
readonly HISTFILE="${XDG_CACHE_HOME:-$HOME/.cache}/fzfg/history"
readonly FZF_OPTS="--reverse --height=100% --no-separator --no-scrollbar --border=none"

# --- State -------------------------------------------------------------------
case_flag=""
pattern=""
opencmd=""
_temp_files=()

# --- Helpers -----------------------------------------------------------------

usage() {
  cat <<EOF
Usage: fzfg [options] [-p <pattern>]

Options:
  -p <pattern>     Initial search pattern (optional)
  -c <open-cmd>    Command to open selected file (e.g. hx, vim)
  -i, --ignore-case  Case-insensitive search
  -h, --help       Show this help message
EOF
  exit 0
}

_temp() {
  local f
  f=$(mktemp) || exit 1
  _temp_files+=("$f")
  echo "$f"
}

_cleanup() {
  rm -f "${_temp_files[@]}"
}
trap _cleanup EXIT

_pty() {
  script -q -c "$*" /dev/null </dev/tty >/dev/tty 2>/dev/null
}

# --- Argument parsing --------------------------------------------------------
for arg; do [[ "$arg" == "--help" ]] && usage; done

while getopts ":p:c:ih" opt; do
  case "$opt" in
    p) pattern="$OPTARG" ;;
    c) opencmd="$OPTARG" ;;
    i) case_flag="-i" ;;
    h) usage ;;
    *) usage ;;
  esac
done

# --- Scratch files -----------------------------------------------------------
items=$(_temp)
reload_cmd=$(_temp)
preview_cmd=$(_temp)
result=$(_temp)

# --- Helper scripts ----------------------------------------------------------
cat > "$reload_cmd" << RELOAD
#!/usr/bin/env bash
q=\$1
[ -z "\$q" ] && cat "$items" && exit
rg --json -U ${case_flag:+"$case_flag"} -e "\$q" 2>/dev/null | python3 -c '
import sys, json
for line in sys.stdin:
    line = line.strip()
    if not line: continue
    try: obj = json.loads(line)
    except: continue
    if obj.get("type") != "match": continue
    data = obj.get("data", {})
    path = data.get("path", {}).get("text", "")
    line_number = data.get("line_number", 0)
    lines_text = data.get("lines", {}).get("text", "")
    line_count = lines_text.count(chr(10))
    if path and line_number:
        print(f"{path}:{line_number}:{line_count}")
' | sed "s|^\\(.*/\\)|$(printf '\033[%sm' "$ANSI_PATH_FG")\1$(printf '\033[%sm' "$ANSI_PATH_FG_DEFAULT")|" | head -200
RELOAD
chmod +x "$reload_cmd"

cat > "$preview_cmd" << 'PREVIEW'
#!/usr/bin/env bash
item=$1 query=$2 buf=$3

if [[ "$item" =~ ^[^:]+:[0-9]+:[0-9]+$ ]]; then
  raw=$(printf '%s' "$item" | sed 's/\x1b\[[0-9;]*m//g')
  count=${raw##*:}
  rest=${raw%:*}
  l=${rest##*:}
  f=${rest%:*}
  [ -z "$f" ] && exit
  bat --color=always --style=numbers --line-range "$((l>buf?l-buf:1))":"$((l+buf))" \
      --highlight-line "$l:$((l+count-1))" "$f" | \
  perl -e '
    my $pat = shift;
    my $hl_bg = shift;
    my $hl_fg = shift;
    my $hl_reset = shift;
    while (<>) {
      chomp;
      my $ansi = $_;
      my $raw = $ansi;
      $raw =~ s/\e\[[0-9;]*m//g;
      my @matches;
      while ($raw =~ /\Q$pat\E/g) {
        push @matches, { pos => pos($raw) - length($&), len => length($&) };
      }
      for my $m (reverse @matches) {
        my $bp = 0;
        my $rc = 0;
        my $sb = -1;
        my $eb = -1;
        while ($bp < length($ansi)) {
          if ($rc == $m->{pos} + $m->{len}) { $eb = $bp; last }
          if (substr($ansi, $bp) =~ /^\e\[[0-9;]*m/) {
            $bp += length($&);
            next;
          }
          $sb = $bp if $rc == $m->{pos};
          $bp++;
          $rc++;
        }
        $eb = $bp if $eb < 0;
        if ($sb >= 0 && $eb > $sb) {
          substr($ansi, $eb, 0) = $hl_reset;
          substr($ansi, $sb, 0) = $hl_bg . $hl_fg;
        }
      }
      print "$ansi\n";
    }
  ' "$query" "$ANSI_WORD_HL_BG" "$ANSI_WORD_HL_FG" "$ANSI_RESET"
else
  pat="$item"
  [ -n "$pat" ] || pat="$query"
  [ -z "$pat" ] && exit
  matches=$(rg -nU $case_flag -e "$pat" 2>/dev/null | head -20)
  [ -z "$matches" ] && exit
  echo "$matches" | perl -pe 'if (/^(.+?):(\d+):(.*)$/) { my ($path, $line, $content) = ($1, $2, $3); if ($path =~ m|(.*/)([^/]+)$|) { my ($dir, $base) = ($1, $2); $_ = "\033[34m$dir\033[39m$base:$line:$ANSI_CONTENT_FG$content\n"; } }'
fi
PREVIEW
sed -i "s/\$case_flag/${case_flag:-}/g" "$preview_cmd"
for var in ANSI_WORD_HL_BG ANSI_WORD_HL_FG ANSI_RESET ANSI_CONTENT_FG; do
  esc=$(printf '%s' "${!var}" | sed 's/[\/&]/\\&/g')
  sed -i "s/\$$var/$esc/g" "$preview_cmd"
done
chmod +x "$preview_cmd"

# --- Main logic --------------------------------------------------------------
initial_query=""
[ -n "$pattern" ] && initial_query="$pattern"

if [ -z "$pattern" ] && [ -s "$HISTFILE" ]; then
  head -n "$MAX_HISTORY" "$HISTFILE" > "$items"
fi

mkdir -p "$(dirname "$HISTFILE")"

binds='tab:replace-query,ctrl-t:toggle-preview,alt-p:preview-up,alt-n:preview-down,alt-t:preview-top'

_pty \
  "SHELL=$(which bash) fzf --ansi --cycle --phony --print-query \
    $FZF_OPTS --prompt=\"\" --info=inline-right \
    --bind=\"$binds\" \
    --bind=\"change:reload:$reload_cmd '{q}'\" \
    --color=\"$FZF_COLORS\" \
    --pointer \">\" \
    --preview \"$preview_cmd {} {q} $BUFFER\" \
    --preview-window right,border-bold \
    ${initial_query:+--query \"$initial_query\"} \
    < $items > $result"

query_text=$(head -1 "$result")
selection=$(tail -1 "$result")
[ -n "$selection" ] || exit 1
[ "$query_text" = "$selection" ] && exit 1

# Save typed query (or selected history item) to history
hist_pattern="$query_text"
[ -z "$hist_pattern" ] && hist_pattern="$selection"
{
  echo "$hist_pattern"
  [ -f "$HISTFILE" ] && grep -vFx "$hist_pattern" "$HISTFILE"
} > "${HISTFILE}.tmp" && mv "${HISTFILE}.tmp" "$HISTFILE"

# Parse result: strip ANSI, determine path:line
raw=$(printf '%s' "$selection" | sed 's/\x1b\[[0-9;]*m//g')
rest=${raw%:*}
l=${rest##*:}
f=${rest%:*}

if [ -n "$opencmd" ]; then
  exec "$opencmd" "$f:$l"
fi
printf '%s\n' "$selection"
