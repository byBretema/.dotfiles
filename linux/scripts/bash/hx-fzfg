#!/usr/bin/env bash
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$script_dir:$PATH"
source "$script_dir/.bash_common"

required_cmd fzfg

result_file="/tmp/hx-fzfg.result"
rm -f "$result_file"

history_dir="${XDG_CACHE_HOME:-$HOME/.cache}/hx-fzfg"
history_file="$history_dir/history"
max_history=100

tmpfile=$(mktemp) || exit 1
trap 'rm -f "$tmpfile" "$tmpfile.result"' EXIT

cat "$history_file" 2>/dev/null > "$tmpfile"

script -q -c \
  "SHELL=$(which bash) fzf --print-query --prompt=\"Pattern: \" \
    --reverse --cycle --height=100% \
    --info=inline-right --no-separator --no-scrollbar \
    --border=none --color=bg+:#313244,pointer:#ffffff,gutter:#1E1E2E \
    --pointer \">\" < $tmpfile > $tmpfile.result" \
  /dev/null </dev/tty >/dev/tty 2>/dev/null

result=$(cat "$tmpfile.result" 2>/dev/null)
query=$(echo "$result" | sed -n '1p')
selection=$(echo "$result" | sed -n '2p')
pattern="${selection:-$query}"
[ -n "$pattern" ] || exit 1

mkdir -p "$history_dir"
{ grep -vxF "$pattern" "$history_file" 2>/dev/null | tail -n $((max_history - 1)); echo "$pattern"; } > "$history_file.tmp"
mv "$history_file.tmp" "$history_file"

selection=$(fzfg "$pattern") || exit 1
clean=$(echo "$selection" | sed 's/\x1b\[[0-9;]*m//g')
[ -n "$clean" ] || exit 1
echo "$clean" > "$result_file"
echo "$clean"
