#!/usr/bin/env bash
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$script_dir:$PATH"
source "$script_dir/.bash_common"

required_cmd fzfg

result_file="/tmp/hx-fzfg.result"
rm -f "$result_file"

history_dir="${XDG_CACHE_HOME:-$HOME/.cache}/hx-fzfg"
history_file="$history_dir/history"
max_history=100

tmpfile=$(mktemp) || exit 1
preview_script=$(mktemp) || exit 1
trap 'rm -f "$tmpfile" "$tmpfile.result" "$preview_script"' EXIT

cat > "$preview_script" <<'PREVIEW_EOF'
#!/usr/bin/env bash
query="$1"
[ -z "$query" ] && echo "Type a pattern to search" && exit 0
matches=$(rg --color never -nU "$query" 2>/dev/null | head -10)
[ -z "$matches" ] && echo "No matches" && exit 0
echo "$matches" | sed 's/^\([^:]*\):\([0-9][0-9]*\):.*$/  \1:\2/'
echo "────────────────────────────────────────"
first=$(echo "$matches" | head -1)
file=${first%%:*}
line=$(echo "$first" | cut -d: -f2)
BUFFER=25
bat --color=always --style=numbers --line-range "$((line>BUFFER?line-BUFFER:1))":"$((line+BUFFER))" \
    --highlight-line "$line":"$((line+1))" "$file" 2>/dev/null
PREVIEW_EOF
chmod +x "$preview_script"

cat "$history_file" 2>/dev/null > "$tmpfile"

script -q -c \
  "SHELL=$(which bash) fzf --print-query --prompt=\"Pattern: \" \
    --reverse --cycle --height=100% \
    --info=inline-right --no-separator --no-scrollbar \
    --border=none --color=bg+:#313244,pointer:#ffffff,gutter:#1E1E2E \
    --pointer \">\" \
    --bind 'ctrl-t:toggle-preview' \
    --preview 'bash $preview_script {q}' \
    --preview-window down:60%,border-bold \
    < $tmpfile > $tmpfile.result" \
  /dev/null </dev/tty >/dev/tty 2>/dev/null

result=$(cat "$tmpfile.result" 2>/dev/null)
query=$(echo "$result" | sed -n '1p')
selection=$(echo "$result" | sed -n '2p')
pattern="${selection:-$query}"
[ -n "$pattern" ] || exit 1

mkdir -p "$history_dir"
{ grep -vxF "$pattern" "$history_file" 2>/dev/null | tail -n $((max_history - 1)); echo "$pattern"; } > "$history_file.tmp"
mv "$history_file.tmp" "$history_file"

selection=$(fzfg "$pattern") || exit 1
clean=$(echo "$selection" | sed 's/\x1b\[[0-9;]*m//g')
[ -n "$clean" ] || exit 1
echo "$clean" > "$result_file"
echo "$clean"
