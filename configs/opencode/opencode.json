{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/deepseek-v4-flash-free",
  "agent": {
    "build":          { "variant": "max" },
    "plan":           { "variant": "max" },
    "general":        { "variant": "max" },
    "explore":        { "variant": "max" }
  },
  "provider": {},
  "permission": {
    "external_directory": {
      "~/agents/**": "allow",
      "~/.dotfiles/**": "allow"
    }
  },
  "lsp": false,
  "formatter": false,
  "share": "disabled",
  "autoupdate": false,
  "compaction": {
    "prune": false
  },
  "experimental": {
    "batch_tool": false,
    "continue_loop_on_deny": false
  },
  "plugin": ["./plugin/auto-agents.ts"]
}
